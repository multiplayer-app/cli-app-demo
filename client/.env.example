VITE_ENVIRONMENT=development
# Multiplayer Session Recorder API Key
# This key is required for recording sessions.
# Note: VITE_ prefix exposes this variable to the browser (intentional for client-side SDK)
VITE_MULTIPLAYER_SDK_API_KEY=MULTIPLAYER_SDK_API_KEY

VITE_SESSION_DEBUGGER_API_BASE_URL=https://api.multiplayer.app
VITE_SESSION_DEBUGGER_EXPORTER_ENDPOINT=https://otlp.multiplayer.app/v1/traces
